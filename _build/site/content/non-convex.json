    if delta < 0 or np.random.random() < np.exp(-delta / T): # Metropolis\n        x = x_new\n    if f_new < best_f:\n        best_x, best_f = x_new, f_new\n        T *= 0.99997 # geometric cooling\nprint(f\"x = {best_x:.4f}, f(x) = {best_f:.4f}\")\n# x = -0.0000, f(x) = 0.0000 <-- found the global minimum!","key":"cUIWCPhXge"},{"type":"outputs","id":"PbaAgXCOfnfyPpuYmw6Eq","children":[],"key":"fc5L64m1rA"}],"key":"ZapsxmPSzD"}],"key":"mSTLL8MftK"},"references":{"cite":{"order":[],"data":{}}}}