.8193em;vertical-align:-0.136em;\"></span><span class=\"mord\">Δ</span><span class=\"mspace\" style=\"margin-right:0.2778em;\"></span><span class=\"mrel\">≥</span><span class=\"mspace\" style=\"margin-right:0.2778em;\"></span></span><span class=\"base\"><span class=\"strut\" style=\"height:0.6444em;\"></span><span class=\"mord\">0</span></span></span></span>","key":"zlOBTQ3LAg"},{"type":"text","value":": accept with probability ","position":{"start":{"line":22,"column":1},"end":{"line":22,"column":1}},"key":"PFswGIxbIG"},{"type":"inlineMath","value":"\\exp(-\\Delta /T)","position":{"start":{"line":22,"column":1},"end":{"line":22,"column":1}},"html":"<span class=\"katex\"><span class=\"katex-mathml\"><math xmlns=\"http://www.w3.org/1998/Math/MathML\"><semantics><mrow><mi>exp</mi><mo>⁡</mo><mo stretchy=\"false\">(</mo><mo>−</mo><mi mathvariant=\"normal\">Δ</mi><mi mathvariant=\"normal\">/</mi><mi>T</mi><mo stretchy=\"false\">)</mo></mrow><annotation encoding=\"application/x-tex\">\\exp(-\\Delta /T)</annotation></semantics></math></span><span class=\"katex-html\" aria-hidden=\"true\"><span class=\"base\"><span class=\"strut\" style=\"height:1em;vertical-align:-0.25em;\"></span><span class=\"mop\">exp</span><span class=\"mopen\">(</span><span class=\"mord\">−</span><span class=\"mord\">Δ/</span><span class=\"mord mathnormal\" style=\"margin-right:0.13889em;\">T</span><span class=\"mclose\">)</span></span></span></span>","key":"xccKWVrj3N"}],"key":"Zjfv7OXYSK"}],"key":"r44yorp7xk"}],"key":"q2gj3F3hZa"}],"enumerator":"1","key":"rahm4OjKx7"}],"key":"XCObEVr33P"},{"type":"block","kind":"notebook-code","children":[{"type":"code","executable":true,"value":"print(\"hi\")","key":"ubUnA2be6X"},{"type":"outputs","id":"Q3tVhLSAp0D7hkt-a0QOK","children":[],"key":"Bl57rkY8nl"}],"key":"aFTG7rMt3y"},{"type":"block","children":[{"type":"comment","value":" ```{code-cell}\nimport numpy as np\nx = 1.7 # same starting point as GD\nbest_x, best_f = x, x**2 - 10*np.cos(2*np.pi*x) + 10\nT = 10.0\nfor k in range(200_000):\n    x_new = x + np.random.randn() * 0.5 # random neighbor\n    f_old = x**2 - 10*np.cos(2*np.pi*x) + 10\n    f_new = x_new**2 - 10*np.cos(2*np.pi*x_new) + 10\n    delta = f_new - f_old\n    if delta < 0 or np.random.random() < np.exp(-delta / T): # Metropolis\n        x = x_new\n    if f_new < best_f:\n        best_x, best_f = x_new, f_new\n        T *= 0.99997 # geometric cooling\nprint(f\"x = {best_x:.4f}, f(x) = {best_f:.4f}\")\n# x = -0.0000, f(x) = 0.0000 <-- found the global minimum!\n```\n ","key":"ejVEdgwU0F"}],"key":"aEaICgJTsH"}],"key":"sPa6ebYWE2"},"references":{"cite":{"order":[],"data":{}}}}